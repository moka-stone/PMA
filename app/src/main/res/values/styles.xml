<resources>
    <style name="CalcButtonMain" parent="TextAppearance.AppCompat.Button">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">0dp</item>
        <item name="backgroundTint">@null</item>
        <item name="layout_constraintDimensionRatio">1:1</item>
        <item name="android:layout_margin">4dp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">36sp</item>
        <item name="android:fontFamily">@font/interreg</item>

        <item name="android:autoSizeMaxTextSize">100sp</item>
        <item name="android:autoSizeMinTextSize">1sp</item>
        <item name="android:autoSizeTextType">uniform</item>
        <item name="android:gravity">center</item>
    </style>

    <style name="CalcButtonsGrey" parent="CalcButtonMain">
        <item name="android:background">@drawable/button_grey</item>
        <item name="android:textSize">47sp</item>
    </style>

    <style name="CalcButtonsOrange" parent="CalcButtonMain">
        <item name="android:background">@drawable/button_orange</item>
        <item name="android:textSize">47sp</item>
    </style>

    <style name="CalcButtonsGrey_Black" parent="CalcButtonMain">
        <item name="android:background">@drawable/button_grey_black</item>
    </style>

</resources>